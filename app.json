{
  "expo": {
    "name": "InventQRy",
    "slug": "InventQRy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/inventqry-icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/InventqrySplashScreen.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "bunsoniumlab.Inventqry",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/inventqry512.png",
        "backgroundColor": "#ffffff"
      },
      "package": "bunsoniumlab.Inventqry"
    },
    "web": {
      "favicon": "./assets/inventqry512.png"
    },
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "7022e9bd-b1d1-44b4-a6d4-f05a377a980b"
      }
    }
  }
}
